---
import { SITE, navItems, isActiveNav } from "../lib/site";

const pathname = Astro.url.pathname;
const navLinkClass = (href: string) =>
  isActiveNav(pathname, href)
    ? "text-white"
    : "text-zinc-300 transition hover:text-white";
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-[#08060b]/78 backdrop-blur-xl">
  <div class="shell flex min-h-16 items-center justify-between gap-4">
    <a href="/" class="group flex shrink-0 items-center gap-3" aria-label={`${SITE.name} home`}>
      <span class="grid h-9 w-9 place-items-center rounded-lg border border-[#ff2d9f]/50 bg-[#ff2d9f]/14 text-sm font-bold text-[#fff7fb] shadow-[0_0_26px_rgba(255,45,159,0.42),inset_0_1px_0_rgba(255,255,255,0.18)]">VO</span>
      <span class="leading-none">
        <span class="block text-sm font-semibold tracking-tight text-white">VibeOps</span>
        <span class="mono block text-[0.66rem] uppercase tracking-[0.22em] text-[#38e8ff]">Forum</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium lg:flex" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          class={navLinkClass(item.href)}
          href={item.href}
          aria-current={isActiveNav(pathname, item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <details class="mobile-nav relative lg:hidden">
        <summary class="flex cursor-pointer list-none items-center rounded-full border border-white/15 px-3 py-2 text-sm font-medium text-white">
          <span class="sr-only">Open menu</span>
          <span aria-hidden="true">Menu</span>
        </summary>
        <nav
          class="absolute right-0 top-[calc(100%+0.5rem)] z-50 min-w-48 rounded-2xl border border-white/12 bg-[#120a16]/95 p-2 shadow-[0_24px_80px_rgba(0,0,0,0.45)] backdrop-blur-xl"
          aria-label="Mobile navigation"
        >
          {navItems.map((item) => (
            <a
              class:list={[
                "block rounded-xl px-4 py-2.5 text-sm font-medium",
                isActiveNav(pathname, item.href)
                  ? "bg-white/10 text-white"
                  : "text-zinc-300 hover:bg-white/6 hover:text-white",
              ]}
              href={item.href}
              aria-current={isActiveNav(pathname, item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </details>

      <a
        href="/join/"
        class="rounded-full bg-[#ff2d9f] px-4 py-2 text-sm font-semibold text-white shadow-[0_0_34px_rgba(255,45,159,0.38)] transition hover:bg-[#ff5fba] active:translate-y-px"
      >
        Join
      </a>
    </div>
  </div>
</header>
