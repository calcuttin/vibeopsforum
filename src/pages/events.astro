---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { formatDate, formatEventTime, SITE } from "../lib/site";
import { getAllEvents, getPastEvents, getUpcomingEvents, eventToJsonLd } from "../lib/events";

const allEvents = await getAllEvents();
const upcomingEvents = getUpcomingEvents(allEvents);
const pastEvents = getPastEvents(allEvents);

const structuredData = [
  ...upcomingEvents.map((event) => eventToJsonLd(event, SITE.url)),
];
---

<BaseLayout
  title="AI Builder Events"
  description="Upcoming VibeOps Forum events for vibecoding, agent operations, A2A protocol, and MCP tooling."
  structuredData={structuredData}
>
  <section class="shell py-20">
    <PageHero
      kicker="Events"
      title="Show the work in progress."
      description="Events are built around practical demos, office hours, and project feedback. Join the Slack to get calendar details and suggest sessions."
    />

    <div class="mt-10 flex flex-wrap gap-4">
      <a class="accent-link text-sm font-bold" href={SITE.eventSubmitUrl}>Suggest an event</a>
      <a class="accent-link text-sm" href={SITE.slackUrl}>Ask in Slack</a>
    </div>

    <div class="mt-12">
      <h2 class="mono text-xs uppercase tracking-[0.35em] text-[#f6ff6a]">Upcoming</h2>
      {upcomingEvents.length > 0 ? (
        <div class="mt-6 divide-y divide-white/10 border-y border-white/10">
          {upcomingEvents.map((event) => (
            <article class="grid gap-5 py-7 md:grid-cols-[12rem_1fr_auto] md:items-start">
              <div>
                <time class="mono text-sm text-[#38e8ff]" datetime={event.data.date.toISOString()}>
                  {formatDate(event.data.date)}
                </time>
                <p class="mt-2 text-xs text-[#cdb8c4]">{formatEventTime(event.data.date, event.data.timezone)}</p>
              </div>
              <div>
                <h3 class="text-2xl font-bold tracking-[-0.03em] text-white">{event.data.title}</h3>
                <p class="mt-2 text-sm text-[#cdb8c4]">{event.data.location}</p>
                <p class="mt-3 max-w-3xl text-sm leading-6 text-[#cdb8c4]">{event.data.description}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {event.data.tags.map((tag) => <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-zinc-400">{tag}</span>)}
                </div>
              </div>
              {event.data.url ? (
                <a class="focus-ring rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-white hover:border-[#38e8ff]/60" href={event.data.url} target="_blank" rel="noopener noreferrer">Event link</a>
              ) : (
                <a class="focus-ring rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-white hover:border-[#38e8ff]/60" href={SITE.slackUrl}>Ask in Slack</a>
              )}
            </article>
          ))}
        </div>
      ) : (
        <div class="mt-6 rounded-2xl border border-dashed border-white/15 bg-black/20 p-6">
          <p class="text-sm leading-6 text-[#cdb8c4]">No upcoming events scheduled. Suggest a session through GitHub or ask in Slack.</p>
        </div>
      )}
    </div>

    {pastEvents.length > 0 && (
      <div class="mt-16">
        <h2 class="mono text-xs uppercase tracking-[0.35em] text-[#38e8ff]">Past sessions</h2>
        <div class="mt-6 divide-y divide-white/10 border-y border-white/10 opacity-80">
          {pastEvents.map((event) => (
            <article class="grid gap-5 py-7 md:grid-cols-[12rem_1fr] md:items-start">
              <div>
                <time class="mono text-sm text-[#38e8ff]" datetime={event.data.date.toISOString()}>
                  {formatDate(event.data.date)}
                </time>
              </div>
              <div>
                <h3 class="text-xl font-semibold tracking-[-0.03em] text-white">{event.data.title}</h3>
                <p class="mt-2 text-sm text-[#cdb8c4]">{event.data.location}</p>
                <p class="mt-3 max-w-3xl text-sm leading-6 text-[#cdb8c4]">{event.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
